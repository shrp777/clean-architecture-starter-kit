meta {
  name: Borrow Book - Book Not Found
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/loans
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "bookId": "non-existent-book-id",
    "memberId": "{{memberId}}"
  }
}

assert {
  res.status: eq 404
}
