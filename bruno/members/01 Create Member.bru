meta {
  name: Create Member
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/members
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Alice Martin",
    "email": "alice@example.com"
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.name: eq Alice Martin
  res.body.email: eq alice@example.com
}
