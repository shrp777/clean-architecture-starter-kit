meta {
  name: 02 - Add Book
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/books
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "title": "Clean Architecture",
    "author": "Robert C. Martin",
    "isbn": "978-0-321-12521-7"
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.title: eq Clean Architecture
  res.body.isbn: isDefined
}

script:post-response {
  bru.setVar("bookId", res.body.id);
}
