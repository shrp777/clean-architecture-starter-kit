meta {
  name: 04 - Borrow Book
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/loans
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "bookId": "{{bookId}}",
    "memberId": "{{memberId}}"
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.bookId: isDefined
  res.body.memberId: isDefined
  res.body.borrowedAt: isDefined
  res.body.returnedAt: isUndefined
}

script:post-response {
  bru.setVar("loanId", res.body.id);
}
